# Run `ghostty +show-config --default --docs` to view a list of
# all available config options and their default values.

theme = iTerm2 Light Background
# theme = tokyonight
font-family = Monego Nerd Font Fix
font-size = 14
# font-synthetic-style = bold-italic
font-feature = -calt
font-feature = -liga
font-feature = -dlig

# The "Standard" Cursor settings
# cursor-style = block
# cursor-color = #000000

# This prevents Vim from trying to "hide" or "recolor" the cursor
# shell-integration-features = no-cursor
shell-integration-features = cursor,sudo,title,ssh-env,ssh-terminfo
bell-features = system,border
mouse-hide-while-typing = true
scrollback-limit = 50000000
cursor-color = cell-foreground
cursor-text = cell-background
adjust-cursor-thickness = 2
selection-foreground = cell-background
selection-background = cell-foreground

cursor-invert-fg-bg = true
cursor-opacity = 0.8

window-vsync = true

clipboard-paste-protection = true
clipboard-paste-bracketed-safe = true
macos-auto-secure-input = true
macos-secure-input-indication = true

# macOS titlebar style
# Options: native, transparent, tabs, hidden
# macos-titlebar-style = transparent

# Window
background-opacity = 0.9
background-blur-radius = 20
